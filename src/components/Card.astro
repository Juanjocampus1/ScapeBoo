---
interface Props {
    cardtitle: string;
    description: string;
    image: string;
}

const { cardtitle, description, image } = Astro.props;
---

<div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 p-8 rounded-xl shadow-2xl transform hover:scale-105 transition duration-300 ease-out max-w-md mx-auto">
    <div class="overflow-hidden rounded-xl">
        <img 
            src={image} 
            alt={cardtitle} 
            class="w-full h-64 md:h-80 lg:h-96 object-cover transition-transform duration-500 transform hover:scale-110"
        />
    </div>
    <h3 class="text-3xl font-bold text-orange-400 spooky-font tracking-wide mt-6">{cardtitle}</h3>
    <p class="mt-4 text-gray-300 leading-relaxed">{description}</p>
</div>
