---
import Layout from '../layouts/Layout.astro';
import Github from '../components/Github.astro';
---

<Layout title="Bienvenido a Mi Escape Room">
	<slot/>
	<header class="bg-halloween overlay h-screen flex flex-col justify-center items-center">
		<h1 class="text-6xl spooky-font text-orange-500 mb-4">¡Feliz Halloween!</h1>
		<p class="text-2xl spooky-font text-white mb-8">Prepara tu disfraz y tus dulces...</p>
		<a href="#main-content" class="px-6 py-3 bg-orange-500 text-black rounded-lg text-lg hover:bg-orange-600 transition">Explorar</a>
	</header>
    <section class="container mx-auto text-center">
		<h2 class="text-4xl font-bold text-white spooky-font mb-8">Actividades de Halloween</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
		<!-- Card 1 -->
		<div class="bg-gray-800 p-6 rounded-lg shadow-lg transform hover:scale-105 transition duration-300">
			<img src="https://example.com/pumpkin.png" alt="Calabazas" class="w-full h-40 object-cover rounded-lg mb-4">
			<h3 class="text-2xl text-orange-400 spooky-font">Tallado de Calabazas</h3>
			<p class="mt-2 text-gray-400">Saca tu creatividad y crea las calabazas más terroríficas.</p>
		</div>

		<!-- Card 2 -->
		<div class="bg-gray-800 p-6 rounded-lg shadow-lg transform hover:scale-105 transition duration-300">
			<img src="https://example.com/ghost.png" alt="Casa Embrujada" class="w-full h-40 object-cover rounded-lg mb-4">
			<h3 class="text-2xl text-orange-400 spooky-font">Casa Embrujada</h3>
			<p class="mt-2 text-gray-400">Atrévete a recorrer la casa más escalofriante de la ciudad.</p>
		</div>

		<!-- Card 3 -->
		<div class="bg-gray-800 p-6 rounded-lg shadow-lg transform hover:scale-105 transition duration-300">
			<img src="https://example.com/candy.png" alt="Dulces o Travesura" class="w-full h-40 object-cover rounded-lg mb-4">
			<h3 class="text-2xl text-orange-400 spooky-font">Dulces o Travesura</h3>
			<p class="mt-2 text-gray-400">Recorre el vecindario y consigue todos los dulces que puedas.</p>
		</div>
		</div>
	</section>

	<!-- Aquí se agregan los iconos de redes sociales al footer -->
	<slot name="social">
	<div>
		<Github ref="https://github.com/Juanjocampus1/ScapeBoo.git" />
	  </div>
	</slot>
  </Layout>
  

